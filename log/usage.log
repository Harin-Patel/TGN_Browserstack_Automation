    "    await page.getByRole('button', {\n" +
    "      name: 'Update'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/Education history updated/i);\n' +
    "    page.once('dialog', d => d.accept());\n" +
    "    await page.getByRole('button', {\n" +
    "      name: 'Delete education history'\n" +
