    '    }).click();\n' +
    "    await page.getByRole('heading', {\n" +
    "      name: 'Edit Certificate'\n" +
    '    }).last().waitFor({\n' +
    "      state: 'visible',\n" +
    '      timeout: 30000\n' +
    '    });\n' +
    '    const updated = `${certNumber}-U`;\n' +
    `    await page.locator('input[name="number"]').fill(updated);\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Update'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/Certificate updated successfully/i);\n' +
