  test_code: 'async ({\n' +
    '    page\n' +
    '  }) => {\n' +
    '    const loginPage = new LoginPage(page);\n' +
    '    const profilePage = new ProfilePage(page);\n' +
    "    const email = process.env.TGN_TEST_EMAIL || 'james@mailinator.com';\n" +
    "    const password = process.env.TGN_TEST_PASSWORD || 'Harin123';\n" +
    '    await loginPage.loginAndExpectJobsLanding(email, password);\n' +
    '    await profilePage.goto();\n' +
    "    await profilePage.openProfileSectionWithAddControl('Certificates', 'Add Certificate');\n" +
    "    await profilePage.scrollSectionHeadingIntoView('Certificates');\n" +
    "    await profilePage.openSectionAddForm('Add Certificate', 'Add New Certificate');\n" +
    '    const certNumber = `E2E-CERT-${Date.now()}`;\n' +
    `    await page.locator('select[name="certificateTypeId"]').selectOption({\n` +
    '      index: 1\n' +
    '    });\n' +
    `    await page.locator('input[name="number"]').fill(certNumber);\n` +
    `    await page.locator('input[name="expireDate"]').fill('2030-12-31');\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Add Certificate'\n" +
    '    }).last().click();\n' +
    '    await expect(page.getByText(certNumber, {\n' +
    '      exact: true\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible({\n' +
    '      timeout: 60000\n' +
    '    });\n' +
    '    await profilePage.waitForNotice(/Certificate added successfully/i);\n' +
    "    const card = profilePage.profileItemCardRoot(certNumber, 'Certificate Number');\n" +
    "    await card.getByRole('button', {\n" +
    "      name: 'Edit certificate'\n" +
    '    }).click();\n' +
    "    await page.getByRole('heading', {\n" +
    "      name: 'Edit Certificate'\n" +
    '    }).last().waitFor({\n' +
    "      state: 'visible',\n" +
    '      timeout: 30000\n' +
    '    });\n' +
    '    const updated = `${certNumber}-U`;\n' +
    `    await page.locator('input[name="number"]').fill(updated);\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Update'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/Certificate updated successfully/i);\n' +
    '    await expect(page.getByText(updated, {\n' +
    '      exact: true\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible();\n' +
    "    page.once('dialog', d => d.accept());\n" +
    "    const card2 = profilePage.profileItemCardRoot(updated, 'Certificate Number');\n" +
    "    await card2.getByRole('button', {\n" +
    "      name: 'Delete certificate'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/Certificate deleted successfully/i);\n' +
    '    await expect(page.getByText(updated, {\n' +
