    '    const loginPage = new LoginPage(page);\n' +
    '    const profilePage = new ProfilePage(page);\n' +
    "    const email = process.env.TGN_TEST_EMAIL || 'james@mailinator.com';\n" +
    "    const password = process.env.TGN_TEST_PASSWORD || 'Harin123';\n" +
    '    await loginPage.loginAndExpectJobsLanding(email, password);\n' +
    '    await profilePage.goto();\n' +
    "    await profilePage.openProfileSectionWithAddControl('Education', '+ Add Education');\n" +
    "    await profilePage.scrollSectionHeadingIntoView('Education');\n" +
    "    await profilePage.openSectionAddForm('+ Add Education', 'Add New Education');\n" +
    "    await profilePage.muiAutocompleteOpenAndPick('Search schools...', {\n" +
    '      index: 0\n' +
    '    });\n' +
    "    await profilePage.muiAutocompleteOpenAndPick('Select course of study', {\n" +
    '      index: 0\n' +
    '    });\n' +
    "    await page.getByRole('button', {\n" +
    "      name: 'Add Education'\n" +
    '    }).last().click();\n' +
    '    await profilePage.waitForNotice(/Education history added/i);\n' +
    "    await page.getByRole('button', {\n" +
    "      name: 'Edit education history'\n" +
    '    }).last().click();\n' +
    "    await page.locator('#education-history-form').waitFor({\n" +
    "      state: 'visible',\n" +
    '      timeout: 30000\n' +
    '    });\n' +
    "    await profilePage.muiAutocompleteOpenAndPick('Search schools...', {\n" +
    '      index: 0\n' +
    '    });\n' +
    "    await profilePage.muiAutocompleteOpenAndPick('Select course of study', {\n" +
