  test_code: 'async ({\n' +
    '    page\n' +
    '  }) => {\n' +
    '    const loginPage = new LoginPage(page);\n' +
    '    const profilePage = new ProfilePage(page);\n' +
    "    const email = process.env.TGN_TEST_EMAIL || 'james@mailinator.com';\n" +
    "    const password = process.env.TGN_TEST_PASSWORD || 'Harin123';\n" +
    '    await loginPage.loginAndExpectJobsLanding(email, password);\n' +
    '    await profilePage.goto();\n' +
    "    await profilePage.openProfileSectionWithAddControl('Work History', '+ Add Work History');\n" +
    "    await profilePage.scrollSectionHeadingIntoView('Work History');\n" +
    "    await profilePage.openSectionAddForm('+ Add Work History', 'Add New Work History');\n" +
    "    await profilePage.muiAutocompleteOpenAndPick('Search facilities...', {\n" +
    '      index: 1\n' +
    '    });\n' +
    "    await profilePage.muiAutocompleteOpenAndPick('Search specialties...', {\n" +
    '      index: 1\n' +
    '    });\n' +
    '    const desc = `E2E work history ${Date.now()}`;\n' +
    `    await page.locator('input[name="startDate"]').fill('2019-01-01');\n` +
    `    await page.locator('input[name="endDate"]').fill('2020-12-01');\n` +
    `    await page.locator('textarea[name="description"]').fill(desc);\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Add Work History'\n" +
    '    }).last().click();\n' +
    '    await expect(page.getByText(desc, {\n' +
    '      exact: false\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible({\n' +
    '      timeout: 60000\n' +
    '    });\n' +
    '    await profilePage.waitForNotice(/[Ww]ork history.*added|successfully/i).catch(() => {});\n' +
    '    const card = profilePage.profileItemCardRoot(desc);\n' +
    "    await card.getByRole('button', {\n" +
    "      name: 'Edit work history'\n" +
    '    }).click();\n' +
    "    await page.getByRole('heading', {\n" +
    "      name: 'Edit Work History'\n" +
    '    }).last().waitFor({\n' +
    "      state: 'visible',\n" +
    '      timeout: 30000\n' +
    '    });\n' +
    '    const updated = `${desc} — updated`;\n' +
    `    await page.locator('textarea[name="description"]').fill(updated);\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Update'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/Work history updated/i);\n' +
    '    await expect(page.getByText(updated, {\n' +
    '      exact: false\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible();\n' +
    "    page.once('dialog', d => d.accept());\n" +
    '    const card2 = profilePage.profileItemCardRoot(updated);\n' +
    "    await card2.getByRole('button', {\n" +
    "      name: 'Delete work history'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/Work history entry deleted/i);\n' +
    '    await expect(page.getByText(updated, {\n' +
    '      exact: false\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    })).toHaveCount(0);\n' +
    '  }',
