    "    await profilePage.openProfileSectionWithAddControl('Certificates', 'Add Certificate');\n" +
    "    await profilePage.scrollSectionHeadingIntoView('Certificates');\n" +
    "    await profilePage.openSectionAddForm('Add Certificate', 'Add New Certificate');\n" +
    '    const certNumber = `E2E-CERT-${Date.now()}`;\n' +
    `    await page.locator('select[name="certificateTypeId"]').selectOption({\n` +
    '      index: 1\n' +
    '    });\n' +
    `    await page.locator('input[name="number"]').fill(certNumber);\n` +
    `    await page.locator('input[name="expireDate"]').fill('2030-12-31');\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Add Certificate'\n" +
    '    }).last().click();\n' +
    '    await expect(page.getByText(certNumber, {\n' +
    '      exact: true\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible({\n' +
    '      timeout: 60000\n' +
    '    });\n' +
    '    await profilePage.waitForNotice(/Certificate added successfully/i);\n' +
    "    const card = profilePage.profileItemCardRoot(certNumber, 'Certificate Number');\n" +
    "    await card.getByRole('button', {\n" +
