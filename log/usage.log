  test_code: 'async ({\n' +
    '    page\n' +
    '  }) => {\n' +
    '    const loginPage = new LoginPage(page);\n' +
    '    const profilePage = new ProfilePage(page);\n' +
    "    const email = process.env.TGN_TEST_EMAIL || 'james@mailinator.com';\n" +
    "    const password = process.env.TGN_TEST_PASSWORD || 'Harin123';\n" +
    '    await loginPage.loginAndExpectJobsLanding(email, password);\n' +
    '    await profilePage.goto();\n' +
    "    await profilePage.openProfileSectionWithAddControl('Specialties', 'Add Certification Specialty');\n" +
    "    await profilePage.scrollSectionHeadingIntoView('Specialties');\n" +
    '    const formTitle = /Add New.*Specialty/i;\n' +
    "    await profilePage.openSectionAddForm('Add Certification Specialty', formTitle);\n" +
    '    await profilePage.specialtyAddFormPickCertificationThenSpecialty();\n' +
    "    const deleteSpecialtyBtns = page.getByRole('button', {\n" +
    "      name: 'Delete certification specialty'\n" +
    '    });\n' +
    '    const rowCountBefore = await deleteSpecialtyBtns.count();\n' +
    "    await page.getByRole('button', {\n" +
    "      name: 'Add Specialty'\n" +
    '    }).click();\n' +
    '    await expect.poll(async () => (await deleteSpecialtyBtns.count()) > rowCountBefore, {\n' +
    '      timeout: 60000\n' +
    '    }).toBeTruthy();\n' +
    '    await profilePage.waitForNotice(/Certification specialty added/i).catch(() => {});\n' +
    "    page.once('dialog', d => d.accept());\n" +
    "    await page.getByRole('button', {\n" +
    "      name: 'Delete certification specialty'\n" +
    '    }).last().click();\n' +
    '    await profilePage.waitForNotice(/Certification specialty deleted/i);\n' +
    '  }',
  test_tags: [],
