  test_code: 'async ({\n' +
    '    page\n' +
    '  }) => {\n' +
    '    const loginPage = new LoginPage(page);\n' +
    '    const profilePage = new ProfilePage(page);\n' +
    "    const email = process.env.TGN_TEST_EMAIL || 'james@mailinator.com';\n" +
    "    const password = process.env.TGN_TEST_PASSWORD || 'Harin123';\n" +
    '    await loginPage.loginAndExpectJobsLanding(email, password);\n' +
    '    await profilePage.goto();\n' +
    "    await profilePage.openProfileSectionWithAddControl('Professional Licenses', '+ Add License');\n" +
    "    await profilePage.scrollSectionHeadingIntoView('Professional Licenses');\n" +
    "    await profilePage.openSectionAddForm('+ Add License', 'Add New License');\n" +
    '    await profilePage.licenseAddFormPickLicenseType();\n' +
    '    await profilePage.licenseAddFormPickState();\n' +
    '    const licNumber = `E2E-LIC-${Date.now()}`;\n' +
    `    await page.locator('input[name="number"]').fill(licNumber);\n` +
    `    await page.locator('input[name="expireDate"]').fill('2032-06-15');\n` +
    '    await profilePage.submitAddLicenseInlineForm();\n' +
    '    await expect(page.getByText(licNumber, {\n' +
    '      exact: true\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible({\n' +
    '      timeout: 60000\n' +
    '    });\n' +
    '    await profilePage.waitForNotice(/[Ll]icense.*added|[Ll]icense added|successfully/i);\n' +
    "    const card = profilePage.profileItemCardRoot(licNumber, 'License Number');\n" +
    "    await card.getByRole('button', {\n" +
    "      name: 'Edit license'\n" +
    '    }).click();\n' +
    "    await page.getByRole('heading', {\n" +
    "      name: 'Edit License'\n" +
    '    }).last().waitFor({\n' +
    "      state: 'visible',\n" +
    '      timeout: 30000\n' +
    '    });\n' +
    '    const updated = `${licNumber}-U`;\n' +
    `    await page.locator('input[name="number"]').fill(updated);\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Update'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/License updated/i);\n' +
    '    await expect(page.getByText(updated, {\n' +
    '      exact: true\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible();\n' +
    "    page.once('dialog', d => d.accept());\n" +
    "    const card2 = profilePage.profileItemCardRoot(updated, 'License Number');\n" +
    "    await card2.getByRole('button', {\n" +
    "      name: 'Delete license'\n" +
    '    }).click();\n' +
    '    await profilePage.waitForNotice(/License deleted/i);\n' +
    '    await expect(page.getByText(updated, {\n' +
    '      exact: true\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    })).toHaveCount(0);\n' +
    '  }',
