    '  }).click();\n' +
    "  await page.getByRole('link', {\n" +
    "    name: 'Sign in here'\n" +
    '  }).click();\n' +
    '\n' +
    '  // click forgot password\n' +
    "  await page.getByText('Forgot your password? →', {\n" +
    '    exact: true\n' +
    '  }).click();\n' +
    '\n' +
    '  // enter email\n' +
    "  await page.getByPlaceholder('Enter your email address').fill('james@mailinator.com');\n" +
    '\n' +
    '  // submit\n' +
