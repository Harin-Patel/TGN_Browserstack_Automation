  test_code: 'async ({\n' +
    '  page\n' +
    '}) => {\n' +
    "  await page.goto('https://tgn-staging.staffbot.com/');\n" +
    '\n' +
    '  // open login\n' +
    "  await page.getByRole('link', {\n" +
    "    name: 'Login or Create Account'\n" +
    '  }).click();\n' +
    "  await page.getByRole('link', {\n" +
    "    name: 'Sign in here'\n" +
    '  }).click();\n' +
    '\n' +
    '  // click forgot password\n' +
    "  await page.getByText('Forgot your password? →', {\n" +
    '    exact: true\n' +
    '  }).click();\n' +
    '\n' +
    '  // enter email\n' +
    "  await page.getByPlaceholder('Enter your email address').fill('james@mailinator.com');\n" +
    '\n' +
    '  // submit\n' +
    "  await page.getByRole('button', {\n" +
    "    name: 'Send Reset Link'\n" +
    '  }).click();\n' +
    '\n' +
    '  // verify success message\n' +
    "  await expect(page.getByText('Password reset email sent!')).toBeVisible();\n" +
    '\n' +
    '  // back to login\n' +
    "  await page.getByRole('link', {\n" +
    "    name: 'Back to Login'\n" +
    '  }).click();\n' +
    '}',
