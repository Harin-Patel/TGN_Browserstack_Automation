  test_name: 'Create, read, delete certification specialty (no row edit in UI)',
  test_location: '/Users/inx-admin/Documents/TGN_Browserstack_Automation/tests/profile/profile-specialties.spec.js:40',
  test_code: 'async ({\n' +
    '    page\n' +
    '  }) => {\n' +
    '    const loginPage = new LoginPage(page);\n' +
    '    const profilePage = new ProfilePage(page);\n' +
    "    const email = process.env.TGN_TEST_EMAIL || 'james@mailinator.com';\n" +
    "    const password = process.env.TGN_TEST_PASSWORD || 'Harin123';\n" +
    '    await loginPage.loginAndExpectJobsLanding(email, password);\n' +
    '    await profilePage.goto();\n' +
    "    await profilePage.openProfileSectionWithAddControl('Specialties', 'Add Certification Specialty');\n" +
    "    await profilePage.scrollSectionHeadingIntoView('Specialties');\n" +
    '    const formTitle = /Add New.*Specialty/i;\n' +
    "    await profilePage.openSectionAddForm('Add Certification Specialty', formTitle);\n" +
    "    const deleteSpecialtyBtns = page.getByRole('button', {\n" +
    "      name: 'Delete certification specialty'\n" +
    '    });\n' +
    '    const rowCountBefore = await deleteSpecialtyBtns.count();\n' +
    '    let added = false;\n' +
    '    for (let attempt = 0; attempt < 6 && !added; attempt++) {\n' +
    '      const salt = Date.now() + attempt * 924269 + Math.floor(Math.random() * 100000);\n' +
    '      await profilePage.specialtyAddFormPickCertificationThenSpecialty({\n' +
    '        salt\n' +
    '      });\n' +
    '      const rowsBeforeClick = await deleteSpecialtyBtns.count();\n' +
    "      await page.getByRole('button', {\n" +
    "        name: 'Add Specialty'\n" +
    '      }).click();\n' +
    '      try {\n' +
    '        await expect.poll(async () => {\n' +
    '          if ((await deleteSpecialtyBtns.count()) > rowsBeforeClick) return true;\n' +
    '          const toast = page.getByText(/Certification specialty added/i);\n' +
    '          const n = await toast.count();\n' +
    '          for (let i = 0; i < n; i++) {\n' +
    '            if (await toast.nth(i).isVisible()) return true;\n' +
    '          }\n' +
    '          return false;\n' +
    '        }, {\n' +
    '          timeout: 55000\n' +
    '        }).toBeTruthy();\n' +
    '        added = true;\n' +
    '      } catch {\n' +
    "        if (attempt === 5) throw new Error('Could not add a unique certification specialty after 6 attempts (pairs may all exist)');\n" +
    '      }\n' +
    '    }\n' +
    "    page.once('dialog', d => d.accept());\n" +
    "    await page.getByRole('button', {\n" +
    "      name: 'Delete certification specialty'\n" +
    '    }).last().click();\n' +
    '    await profilePage.waitForNotice(/Certification specialty deleted/i);\n' +
    '  }',
  test_tags: [],
  test_started_at: '2026-03-20T09:09:14.817Z',
  test_scope: 'Profile — Specialties - Create, read, delete certification specialty (no row edit in UI)',
  test_scopes: [ 'Profile — Specialties' ],
  test_rerun_name: ' -latest:OSX Sonoma-browserstack profile/profile-specialties.spec.js Profile — Specialties Create, read, delete certification specialty (no row edit in UI)',
