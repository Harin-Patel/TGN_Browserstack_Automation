  test_name: 'Login, listing cards, upload resume, submit application, random detail, pagination',
  test_location: '/Users/inx-admin/Documents/TGN_Browserstack_Automation/tests/jobs/job-listing.spec.js:10',
  test_code: 'async ({\n' +
    '    page\n' +
    '  }) => {\n' +
    '    test.setTimeout(180000);\n' +
    '    const jobsPage = new JobsPage(page);\n' +
    '    const loginPage = new LoginPage(page);\n' +
    "    const email = process.env.TGN_TEST_EMAIL || 'james@mailinator.com';\n" +
    "    const password = process.env.TGN_TEST_PASSWORD || 'Harin123';\n" +
    '    const resumePath = process.env.TGN_TEST_RESUME_PATH || DEFAULT_RESUME_PATH;\n' +
    '    await loginPage.loginAndExpectJobsLanding(email, password);\n' +
    '    await jobsPage.goto();\n' +
    "    await expect(page.getByRole('heading', {\n" +
    "      name: 'Find Your Next Travel Nursing Job'\n" +
    '    })).toBeVisible();\n' +
    '    await expect(page.getByText(/Showing \\d+ jobs\\(of [\\d,]+ total\\)/)).toBeVisible();\n' +
    '    const titles = jobsPage.jobTitleHeadings();\n' +
    '    await expect(titles.first()).toBeVisible();\n' +
    '    const cardCount = await titles.count();\n' +
    '    expect(cardCount).toBeGreaterThanOrEqual(12);\n' +
    "    await expect(page.getByRole('button', {\n" +
    "      name: 'View more'\n" +
    '    }).first()).toBeVisible();\n' +
    '    await jobsPage.openFirstJobDetailWithApplyNow();\n' +
    '    await expect(page).toHaveURL(/\\/jobs\\/job/);\n' +
    '    await expect(page).toHaveURL(/jobId=/);\n' +
    "    await expect(page.getByRole('button', {\n" +
    "      name: 'Apply Now'\n" +
    '    })).toBeVisible();\n' +
    '    await jobsPage.revealApplicationForm();\n' +
    '    await expect(page.getByText(/Apply for /)).toBeVisible();\n' +
    "    await expect(page.getByText('Resume/CV').first()).toBeVisible();\n" +
    '    await expect(page.getByText(/Drag and drop your resume here/i).first()).toBeVisible();\n' +
    '    await jobsPage.uploadResumeFile(resumePath);\n' +
    '    await jobsPage.submitApplicationWithResume();\n' +
    "    await expect(page.getByText('Application submitted successfully!')).toBeVisible();\n" +
    "    await expect(page.getByRole('button', {\n" +
    "      name: 'Applied'\n" +
    '    }).first()).toBeVisible();\n' +
    '    await jobsPage.gotoJobsListing();\n' +
    '    const pickIndex = Math.floor(Math.random() * cardCount);\n' +
    '    await jobsPage.openJobDetailByTitleIndex(pickIndex);\n' +
    '    await expect(page).toHaveURL(/\\/jobs\\/job/);\n' +
    '    await expect(page).toHaveURL(/jobId=/);\n' +
    '    await jobsPage.gotoJobsListing();\n' +
    '    const countBefore = await jobsPage.getShowingJobsCount();\n' +
    '    expect(countBefore).toBeGreaterThan(0);\n' +
    '    await jobsPage.scrollToTriggerNextJobsPage();\n' +
    '    await expect.poll(async () => jobsPage.getShowingJobsCount(), {\n' +
    '      timeout: 60000\n' +
    '    }).toBeGreaterThan(countBefore);\n' +
    '  }',
  test_tags: [],
