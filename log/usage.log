    "    name: 'Send Reset Link'\n" +
    '  }).click();\n' +
    '\n' +
    '  // verify success message\n' +
    "  await expect(page.getByText('Password reset email sent!')).toBeVisible();\n" +
    '\n' +
    '  // back to login\n' +
    "  await page.getByRole('link', {\n" +
    "    name: 'Back to Login'\n" +
    '  }).click();\n' +
    '}',
