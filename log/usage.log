    `    await page.locator('input[name="startDate"]').fill('2019-01-01');\n` +
    `    await page.locator('input[name="endDate"]').fill('2020-12-01');\n` +
    `    await page.locator('textarea[name="description"]').fill(desc);\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Add Work History'\n" +
    '    }).last().click();\n' +
    '    await expect(page.getByText(desc, {\n' +
    '      exact: false\n' +
    '    }).filter({\n' +
    '      visible: true\n' +
    '    }).first()).toBeVisible({\n' +
    '      timeout: 60000\n' +
    '    });\n' +
    '    await profilePage.waitForNotice(/[Ww]ork history.*added|successfully/i).catch(() => {});\n' +
    '    const card = profilePage.profileItemCardRoot(desc);\n' +
    "    await card.getByRole('button', {\n" +
    "      name: 'Edit work history'\n" +
    '    }).click();\n' +
    "    await page.getByRole('heading', {\n" +
    "      name: 'Edit Work History'\n" +
    '    }).last().waitFor({\n' +
    "      state: 'visible',\n" +
    '      timeout: 30000\n' +
    '    });\n' +
    '    const updated = `${desc} — updated`;\n' +
    `    await page.locator('textarea[name="description"]').fill(updated);\n` +
    "    await page.getByRole('button', {\n" +
    "      name: 'Update'\n" +
